# FinAlly frontend env vars.
# NEXT_PUBLIC_* vars are inlined into the public bundle at build time.

# Base URL the browser prepends to /api/* requests.
# - Empty/unset  → relative paths; works same-origin in prod (FastAPI serves both)
# - http://localhost:8000 → use this in `next dev` (frontend on :3000, backend on :8000)
NEXT_PUBLIC_API_BASE_URL=