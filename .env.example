# FinAlly — environment variable template
# Copy this file to .env and fill in your values.
# .env is gitignored; only .env.example is committed.

# Required: OpenRouter API key for LLM chat functionality
# Obtain from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: Set to "true" to use deterministic mock LLM responses (no API key needed)
# Useful for local development, E2E tests, and CI/CD pipelines
LLM_MOCK=false

# Optional: Massive (Polygon.io) API key for real market data
# If not set, the built-in GBM market simulator is used (recommended for most users)
MASSIVE_API_KEY=

# Optional: SQLite database file path (default: db/finally.db)
# In Docker the db/ directory is volume-mounted for persistence across restarts
DB_PATH=db/finally.db

# Optional: SSE snapshot interval in seconds (default: 0.5)
# Controls how often price updates are pushed to connected browser clients
SNAPSHOT_INTERVAL=0.5

# Optional: Static files directory served by FastAPI (default: static)
# In production this is populated by the Next.js build stage in the Dockerfile
STATIC_DIR=static
