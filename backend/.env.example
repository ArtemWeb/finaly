# FinAlly backend environment variables.
# Copy to .env and fill in the values you need; .env is gitignored.

# SQLite database file path (volume-mounted at /app/db in Docker).
DB_PATH=db/finally.db

# Periodic portfolio snapshot interval in seconds.
SNAPSHOT_INTERVAL=30

# Directory from which FastAPI serves the Next.js static export.
# Leave at the default in production; the Phase 4 Dockerfile copies `frontend/out/*`
# into this directory during the build stage.
STATIC_DIR=static

# Polygon.io / Massive market data API key.
# Leave blank to use the bundled GBM simulator; set to enable real prices.
MASSIVE_API_KEY=

# OpenRouter API key for the AI chat assistant.
# Leave blank (and LLM_MOCK off) to disable the chat panel in the UI.
OPENROUTER_API_KEY=

# When set to "true", the chat endpoint returns a deterministic mock reply
# without calling any external LLM. Useful for local development and tests.
LLM_MOCK=false

# Comma-separated list of allowed CORS origins.
# Leave empty in production (same-origin: FastAPI serves both the API and the
# static export). Set to `http://localhost:3000` for `next dev` against this
# backend on :8000. Never use "*" — allow_origins is always an explicit list.
CORS_ORIGINS=